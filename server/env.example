# Port sur lequel tourne l'API
PORT=3001

# URL de connexion PostgreSQL
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://opus:CHANGE_MOI@localhost:5432/opus

# Origine autorisée pour le CORS (IP ou domaine du frontend)
# En local sur le même réseau : http://192.168.1.XX
CORS_ORIGIN=http://192.168.1.XX
